{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LanMigrate",
  "version": "0.3.0",
  "identifier": "app.lanmigrate.gui",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LanMigrate - 局域网迁移",
        "width": 880,
        "height": 660,
        "minWidth": 720,
        "minHeight": 540,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/lanmigrate"],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}
